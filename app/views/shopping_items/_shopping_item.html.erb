<%= tag.li id: dom_id(item), class: "item",
      data: (item.open? ? { controller: "gesture", gesture_reorder_url_value: reorder_shopping_items_path } : {}) do %>
  <div class="item__name">
    <%= turbo_frame_tag dom_id(item, :name) do %>
      <%= link_to item.name, edit_shopping_item_path(item), class: "item__label", draggable: false %>
    <% end %>
  </div>

  <%= button_to toggle_shopping_item_path(item),
        method: :patch,
        class: "item__circle",
        form_class: "item__toggle",
        aria: { label: item.open? ? "Mark as done" : "Move back to list" } do %>
  <% end %>
<% end %>
